/**
 * file: .env.example
 * description: 环境变量模板 · 生产/开发环境 API 地址配置
 * author: YanYuCloudCube Team
 * version: v1.0.0
 * created: 2026-07-12
 * updated: 2026-07-12
 * status: active
 * tags: [config],[env],[template]
 *
 * brief: 环境变量示例，复制为 .env / .env.production 填入实际值
 *
 * details:
 * - VITE_API_URL: 后端 dashboard/server.py 的 HTTP 基址
 * - 留空时前端走同源请求，后端不可达时降级到内置 mock 数据
 * - 不可在此文件填入密钥，仅作为模板
 *
 * usage:
 *   cp .env.example .env              # 开发
 *   cp .env.example .env.production   # 生产构建
 */

# 后端 API 基址（不含末尾斜杠）
# 开发本地: 留空 = 同源请求（Vite dev server 代理）
# 生产:    填后端实际地址，如 https://api.dynasty.yyc3.com
VITE_API_URL=

# 联调模式（可选）：设为 true 时禁止 Mock 回退，后端不可达直接抛错
# 用于联调期间暴露真实 API 问题，避免 Mock 数据掩盖错误
# VITE_STRICT_API=true

# 构建时注入的其他变量（按需添加，必须以 VITE_ 前缀开头）
# VITE_WS_URL=wss://api.dynasty.yyc3.com/ws
