{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "composite": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "./node_modules/.cache/tsc-node",
    "types": ["node"]
  },
  "include": ["vite.config.ts", "vitest.config.ts"]
}
